@page
@model BookstoreApp.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<h1>Shopping Cart</h1>

@if (Model.CartItems.Count == 0)
{
    <p>Your cart is empty.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Book</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.CartItems)
            {
                <tr>
                    <td>@item.Book.Title</td>
                    <td>$@item.Book.Price</td>
                    <td>@item.Quantity</td>
                    <td>$@(item.Book.Price * item.Quantity)</td>
                    <td>
                        <form method="post" asp-page-handler="RemoveFromCart" class="d-inline">
                            <input type="hidden" name="bookId" value="@item.Book.Id" />
                            <button type="submit" class="btn btn-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-right"><strong>Grand Total:</strong></td>
                <td><strong>$@Model.TotalAmount</strong></td>
                <td></td>
            </tr>
        </tfoot>
    </table>
    
    <div class="mt-3">
        <a asp-action="Checkout" asp-controller="Order" class="btn btn-primary">Proceed to Checkout</a>
    </div>
}
