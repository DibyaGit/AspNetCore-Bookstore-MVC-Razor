@model IEnumerable<BookstoreApp.Models.Book>

@{
    ViewData["Title"] = "Books";
}

<h1>Books Catalog</h1>

<p>
    <a href="/BookManagement/Create" class="btn btn-primary">Add New Book (Admin)</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>$@item.Price</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">Details</a> |
                <a href="/BookManagement/Edit/@item.Id" class="btn btn-warning">Edit</a> |
                <a href="/BookManagement/Delete/@item.Id" class="btn btn-danger">Delete</a> |
                <form method="post" asp-page="/Cart/Index" asp-page-handler="AddToCart" class="d-inline">
                    <input type="hidden" name="bookId" value="@item.Id" />
                    <button type="submit" class="btn btn-success">Add to Cart</button>
                </form>
            </td>
        </tr>
}
    </tbody>
</table>
