@model BookstoreApp.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<h1>Book Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@Model.Author</dd>

        <dt class="col-sm-2">ISBN</dt>
        <dd class="col-sm-10">@Model.ISBN</dd>

        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">$@Model.Price</dd>
    </dl>
</div>
<div>
    <form method="post" asp-page="/Cart/Index" asp-page-handler="AddToCart" class="d-inline">
        <input type="hidden" name="bookId" value="@Model.Id" />
        <button type="submit" class="btn btn-success">Add to Cart</button>
    </form>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
