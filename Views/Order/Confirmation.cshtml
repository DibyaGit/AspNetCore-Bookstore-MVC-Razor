@model BookstoreApp.Models.Order

@{
    ViewData["Title"] = "Order Confirmation";
}

<h1>Order Confirmation</h1>

<div class="alert alert-success">
    <h4>Thank you for your order!</h4>
    <p>Your order has been placed successfully.</p>
</div>

<div>
    <h4>Order Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Order ID</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Order Date</dt>
        <dd class="col-sm-10">@Model.OrderDate</dd>

        <dt class="col-sm-2">Total Amount</dt>
        <dd class="col-sm-10">$@Model.TotalAmount</dd>
    </dl>
</div>

<a href="/Books" class="btn btn-primary">Continue Shopping</a>
